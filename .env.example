# Copy this file to `.env` and fill in your values. Vite inlines every VITE_*
# variable into the build at build time — do NOT commit a real key.

# OpenAI API key. NOTE: this is currently inlined into the built bundle and is
# therefore extractable from the shipped extension (see audit issue #7).
VITE_OPENAI_API_KEY=

# Model used for text renarration.
VITE_OPENAI_TEXT_MODEL=gpt-5.5

# Model used for vision / image understanding.
VITE_OPENAI_VISION_MODEL=gpt-5.5

# Image detail level sent to the OpenAI API: `low` or `high`.
# Default is `low` — cheaper/faster and sufficient for renarration.
VITE_OPENAI_IMAGE_DETAIL=low

# Request timeout in milliseconds.
VITE_OPENAI_TIMEOUT_MS=120000
